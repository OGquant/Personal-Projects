# Copy to .env — NEVER commit the actual .env file
# ─────────────────────────────────────────────────────────────────────────────

# FRED (Federal Reserve Economic Data)
# Free key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# NewsAPI (for richer news beyond RSS)
# Free tier: 100 req/day — https://newsapi.org/register
NEWS_API_KEY=

# Polymarket — no key needed for read-only gamma/CLOB API
# Uncomment if they add auth in future
# POLYMARKET_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# ZERODHA KITE CONNECT
# Docs: https://developers.kite.trade/
#
# Step 1: Create app at https://developers.kite.trade/apps
#         → Get KITE_API_KEY and KITE_API_SECRET
#
# Step 2: Generate access token daily (valid until next trading day 6:30 AM):
#         from kiteconnect import KiteConnect
#         kite = KiteConnect(api_key="YOUR_API_KEY")
#         print(kite.login_url())  # open in browser, copy request_token from redirect URL
#         data = kite.generate_session("REQUEST_TOKEN", api_secret="YOUR_SECRET")
#         print(data["access_token"])  # paste below
#
# Step 3: Set both values below. The terminal will auto-detect and enable:
#         - Live MCX tick quotes (Gold, Silver, all variants)
#         - Real MCX option chains (live IV surface)
#         - Intraday OHLCV (5-min bars for realized vol)
#         - WebSocket streaming for real-time vol computation
#
# Without these keys the terminal still works fully — it falls back to
# yfinance for all data (slightly delayed, no MCX option chains).
# ─────────────────────────────────────────────────────────────────────────────
KITE_API_KEY=
KITE_ACCESS_TOKEN=

# Logging
LOG_LEVEL=INFO
